/* AI-Team TUI Dashboard — Textual CSS */

Screen {
    background: $surface;
}

.hidden {
    display: none;
}

#connection-banner, #hitl-banner {
    height: auto;
    padding: 0 1;
    background: $primary-darken-3;
}

#dashboard-layout {
    height: 1fr;
}

#run-sidebar {
    width: 32;
    border: solid $primary;
    padding: 0 1;
}

#run-list {
    height: 1fr;
    border: solid $primary-darken-2;
}

#dashboard-main {
    height: 1fr;
}

#dashboard-panels {
    height: 12;
}

#dashboard-log-row {
    height: 1fr;
}

#phase-pipeline {
    height: 3;
    border: solid $primary;
    padding: 0 1;
}

#agent-timeline {
    height: auto;
    max-height: 8;
    border: solid cyan;
    padding: 0 1;
}

#run-summary {
    height: auto;
    border: solid green;
    padding: 0 1;
}

#agents-panel {
    border: solid green;
    padding: 0;
    width: 1fr;
}

#metrics-panel {
    border: solid magenta;
    padding: 0;
    width: 1fr;
}

#log-panel {
    border: solid yellow;
    padding: 0;
    width: 1fr;
    height: 100%;
}

#guardrails-panel {
    border: solid red;
    padding: 0;
    width: 1fr;
    height: 100%;
}

#how-it-works {
    padding: 1;
    border: dashed $primary-darken-1;
}

#hitl-panel {
    padding: 1;
    border: solid yellow;
}

#run-form {
    padding: 1 2;
    height: auto;
}

#run-form Label {
    margin: 1 0 0 0;
}

#run-output {
    border: solid $primary;
    padding: 1;
    height: 1fr;
}

#compare-form {
    padding: 1;
    height: auto;
}

#compare-grid {
    layout: grid;
    grid-size: 3 1;
    grid-gutter: 1;
    padding: 1;
    height: 1fr;
}

#compare-crewai, #compare-langgraph, #compare-claude {
    border: solid $primary;
    padding: 0;
    overflow-y: auto;
}

#compare-summary {
    height: 14;
    border: solid cyan;
    padding: 0;
}

#artifacts-layout {
    height: 1fr;
}

#artifact-files-panel {
    width: 40%;
    border: solid $primary;
}

#artifact-content-panel {
    width: 1fr;
    border: solid green;
    padding: 1;
}

TabPane {
    padding: 0;
}
