# ai-team environment template
# Copy to .env and adjust values.

# =============================================================================
# OPENROUTER (inference — 3-tier: dev / test / prod)
# =============================================================================
# API key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Active tier: dev (cheapest), test (better quality), prod (portfolio demos)
AI_TEAM_ENV=dev
# OpenRouter endpoint; leave as-is unless using a proxy
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Shown on OpenRouter leaderboards
OR_SITE_URL=https://github.com/yourusername/ai-team
OR_APP_NAME=AI-Team-Capstone

# Cost controls
# Pre-run estimate ceiling: abort if the cost estimate exceeds this (USD)
AI_TEAM_MAX_COST_PER_RUN=5.00
# Runtime spend guard: hard, non-retryable abort once actual spend crosses this
# (USD). 0 disables the ceiling; tracking still runs. Default 5.0.
# AI_TEAM_RUN_BUDGET_USD=5.0
# Show cost estimate before execution (true/false)
AI_TEAM_SHOW_COST_ESTIMATE=true
# Require confirmation before prod runs
AI_TEAM_PROD_CONFIRM=true

# Integration tests: set to 1 to run crew-level tests against real OpenRouter
# AI_TEAM_USE_REAL_LLM=0
# AI_TEAM_TEST_MEMORY=0  # Set to 1 to run memory/embedder integration tests

# Project / crew
# PROJECT_PLANNING_SEQUENTIAL=0

# =============================================================================
# GUARDRAILS (prefix GUARDRAIL_)
# =============================================================================
# Retries are per guardrail category (no single GUARDRAIL_MAX_RETRIES):
# GUARDRAIL_BEHAVIORAL_MAX_RETRIES=3
# GUARDRAIL_SECURITY_MAX_RETRIES=3
# GUARDRAIL_QUALITY_MAX_RETRIES=3
# GUARDRAIL_CODE_QUALITY_MIN_SCORE=0.7
# GUARDRAIL_TEST_COVERAGE_MIN=0.6
# GUARDRAIL_MAX_FILE_SIZE_KB=500

# =============================================================================
# MEMORY (prefix MEMORY_; long-term store is SQLite)
# =============================================================================
# MEMORY_SQLITE_PATH=./data/memory.db
# MEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small
# MEMORY_MEMORY_ENABLED=true
# MEMORY_RETENTION_DAYS=90

# =============================================================================
# CREWAI (--backend crewai)
# =============================================================================
# Wall-clock ceiling before force-killing the subprocess-isolated CrewAI run.
# CREWAI_HARD_TIMEOUT_SECONDS=900

# =============================================================================
# LANGGRAPH (--backend langgraph)
# =============================================================================
# placeholder = stub nodes (CLI default); full = planning/dev/test/deploy subgraphs
# AI_TEAM_LANGGRAPH_GRAPH_MODE=full
# Optional Postgres checkpointing; unset falls back to SQLite.
# AI_TEAM_LANGGRAPH_POSTGRES_URI=postgresql://user:pass@localhost:5432/ai_team

# =============================================================================
# CLAUDE AGENT SDK (--backend claude-agent-sdk)
# =============================================================================
# Direct Anthropic API key (not OpenRouter). Requires Claude Code / SDK runtime.
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Runtime smoke loop: boot the generated app and probe it after a clean run.
# ANTHROPIC_SMOKE_LOOP_ENABLED=true
# ANTHROPIC_SMOKE_MAX_ATTEMPTS=2
